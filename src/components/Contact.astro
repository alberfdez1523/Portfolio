---
---

<section id="contact" class="py-32 relative">
  <!-- Top divider -->
  <div class="overflow-hidden py-6 border-y t-border mb-20">
    <div class="flex animate-marquee whitespace-nowrap">
      {[...Array(2)].map(() => (
        <div class="flex items-center gap-8 mx-4">
          {['CONTACTO', '→', 'HABLEMOS', '→', 'COLABOREMOS', '→', 'CONTACTO', '→', 'HABLEMOS', '→'].map((word) => (
            <span class={`font-['Space_Grotesk'] text-3xl md:text-5xl font-bold ${word === '→' ? 't-accent' : 't-text-05'} shrink-0`}>
              {word}
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid lg:grid-cols-2 gap-16">
      <!-- Left side -->
      <div class="space-y-8">
        <div class="reveal"><span class="section-label" data-i18n="contact.label">Contacto</span></div>
        <h2 class="text-4xl md:text-6xl font-['Space_Grotesk'] font-bold leading-tight reveal" style="transition-delay:0.1s;">
          <span data-i18n="contact.t1">¿Tienes un proyecto</span><span class="t-accent" data-i18n="contact.t2"> en mente?</span>
        </h2>
        <p class="t-text-40 text-lg max-w-md reveal" style="transition-delay:0.2s;" data-i18n="contact.desc">
          Estoy abierto a nuevas oportunidades. Si tienes alguna pregunta o propuesta, no dudes en contactarme.
        </p>

        <!-- Contact cards -->
        <div class="space-y-4 reveal" style="transition-delay:0.3s;">
          <a href="https://mail.google.com/mail/?view=cm&fs=1&to=alberfdez2000@gmail.com&su=Contacto%20desde%20Portfolio&body=Hola%20Alberto%2C%0A%0AMe%20gustar%C3%ADa%20ponerme%20en%20contacto%20contigo.%0A%0A" target="_blank" class="group flex items-center gap-5 glass glass-hover rounded-2xl p-5" data-cursor>
            <div class="w-14 h-14 rounded-xl accent-bg-10 accent-border border flex items-center justify-center shrink-0 group-hover:bg-[color-mix(in_srgb,var(--c-accent)_20%,transparent)] transition-colors">
              <svg class="w-6 h-6 t-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            </div>
            <div>
              <div class="font-['JetBrains_Mono'] text-[10px] t-text-30 uppercase tracking-wider" data-i18n="contact.email">Email</div>
              <div class="font-['Space_Grotesk'] t-text-70 group-hover:t-accent transition-colors">alberfdez2000@gmail.com</div>
            </div>
            <svg class="w-5 h-5 t-text-20 ml-auto group-hover:t-accent group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
          </a>

          <div class="flex items-center gap-5 glass rounded-2xl p-5">
            <div class="w-14 h-14 rounded-xl accent2-bg-10 accent2-border border flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 t-accent2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            </div>
            <div>
              <div class="font-['JetBrains_Mono'] text-[10px] t-text-30 uppercase tracking-wider" data-i18n="contact.location">Ubicación</div>
              <div class="font-['Space_Grotesk'] t-text-70">España 🇪🇸</div>
            </div>
          </div>


        </div>
      </div>

      <!-- Right side: Big CTA -->
      <div class="flex flex-col items-center justify-center reveal" style="transition-delay:0.2s;">
        <div class="glass rounded-3xl p-10 md:p-14 w-full text-center relative overflow-hidden">
          <div class="absolute inset-0" style="background:linear-gradient(to bottom right, color-mix(in srgb, var(--c-accent) 5%, transparent), transparent, color-mix(in srgb, var(--c-accent2) 5%, transparent));"></div>
          <div class="relative z-10 space-y-8">
            <div class="w-20 h-20 mx-auto rounded-2xl accent-bg-10 accent-border border flex items-center justify-center">
              <span class="text-4xl">🤝</span>
            </div>
            <h3 class="font-['Space_Grotesk'] text-2xl md:text-3xl font-bold t-text" data-i18n="contact.cta">¡Hablemos!</h3>
            <p class="t-text-40 max-w-sm mx-auto" data-i18n="contact.ctadesc">
              Siempre estoy abierto a discutir nuevos proyectos, ideas creativas u oportunidades.
            </p>
            <a href="https://mail.google.com/mail/?view=cm&fs=1&to=alberfdez2000@gmail.com&su=Contacto%20desde%20Portfolio&body=Hola%20Alberto%2C%0A%0AMe%20gustar%C3%ADa%20ponerme%20en%20contacto%20contigo.%0A%0A" target="_blank" class="inline-flex items-center gap-3 px-8 py-4 accent-bg rounded-full font-['Space_Grotesk'] font-bold text-lg hover:shadow-[0_0_50px_color-mix(in_srgb,var(--c-accent)_30%,transparent)] transition-all duration-500 group" style="color:var(--c-bg);" data-cursor>
              <span data-i18n="contact.btn">Enviar Email</span>
              <svg class="w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
            </a>
            <div class="flex items-center justify-center gap-4 pt-4">
              <span class="text-xs t-text-20 font-['JetBrains_Mono']" data-i18n="contact.or">o encuéntrame en</span>
            </div>
            <div class="flex items-center justify-center gap-3">
              <a href="https://www.linkedin.com/in/alberto-fern%C3%A1ndez-palomo-38a583267/" target="_blank" class="w-12 h-12 glass rounded-xl flex items-center justify-center t-text-40 hover:t-accent transition-all duration-300" data-cursor>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="https://github.com/alberfdez1523" target="_blank" class="w-12 h-12 glass rounded-xl flex items-center justify-center t-text-40 hover:t-accent transition-all duration-300" data-cursor>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
