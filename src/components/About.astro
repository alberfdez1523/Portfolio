---
---

<section id="about" class="py-32 relative">
  <!-- Marquee divider -->
  <div class="overflow-hidden py-8 border-y t-border mb-20">
    <div class="flex animate-marquee whitespace-nowrap">
      {[...Array(2)].map(() => (
        <div class="flex items-center gap-8 mx-4">
          {['SOFTWARE ENGINEER', '✦', 'AI RESEARCHER', '✦', 'FULL-STACK', '✦', 'QUANTUM ML', '✦', 'PROBLEM SOLVER', '✦'].map((word) => (
            <span class={`font-['Space_Grotesk'] text-4xl md:text-6xl font-bold ${word === '✦' ? 't-accent' : 't-text-05'} shrink-0`}>
              {word}
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid lg:grid-cols-5 gap-16 items-start">
      <!-- Left: Image -->
      <div class="lg:col-span-2 reveal">
        <div class="relative group">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden glass">
            <img src="https://alberfdez15.vercel.app/assets/Imagen-TFG.jpg" alt="Alberto trabajando" class="w-full h-full object-cover opacity-70 group-hover:opacity-90 group-hover:scale-105 transition-opacity duration-500" loading="lazy" decoding="async" width="500" height="625" />
            <div class="absolute inset-0" style="background:linear-gradient(to top, var(--c-surface-950), transparent, color-mix(in srgb, var(--c-surface-950) 30%, transparent));"></div>
          </div>

          <div class="absolute -bottom-6 -right-6 max-w-[260px] glass rounded-xl p-5">
            <svg class="w-6 h-6 mb-2" style="color:color-mix(in srgb, var(--c-accent) 40%, transparent);" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
            </svg>
            <p class="text-sm t-text-50 italic leading-relaxed" data-i18n="about.quote">
              El éxito no es la ausencia de fracaso, sino la respuesta a él.
            </p>
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="lg:col-span-3 space-y-8">
        <div class="reveal">
          <span class="section-label" data-i18n="about.label">Sobre mí</span>
        </div>

        <h2 class="text-4xl md:text-5xl font-['Space_Grotesk'] font-bold leading-tight reveal" style="transition-delay:0.1s;">
          <span data-i18n="about.t1">Transformando ideas en</span><span class="t-accent" data-i18n="about.t2"> código</span><span data-i18n="about.t3"> con pasión</span>
        </h2>

        <div class="space-y-5 reveal" style="transition-delay:0.2s;">
          <p class="t-text-50 text-lg leading-relaxed" data-i18n="about.p1">
            Siempre me ha atraído la informática, pero no fue hasta que profundicé más en la
            programación que me di cuenta de que este era realmente mi lugar. Las primeras
            etapas de la universidad no fueron fáciles, pero aprendí a pensar como un ingeniero.
          </p>
          <p class="t-text-50 text-lg leading-relaxed" data-i18n="about.p2">
            Soy apasionado por aprender nuevos lenguajes de programación y enfrentar
            desafíos. Tengo la capacidad de adaptarme rápidamente y absorber conocimiento como una esponja.
          </p>
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-4 pt-4 reveal" style="transition-delay:0.3s;">
          <div class="glass rounded-xl p-5 text-center glass-hover">
            <div class="font-['Space_Grotesk'] font-bold text-3xl t-accent">AI</div>
            <div class="text-xs t-text-40 mt-1 font-['JetBrains_Mono']" data-i18n="about.stat1">Engineer</div>
          </div>
          <div class="glass rounded-xl p-5 text-center glass-hover">
            <div class="font-['Space_Grotesk'] font-bold text-3xl t-accent">5+</div>
            <div class="text-xs t-text-40 mt-1 font-['JetBrains_Mono']" data-i18n="about.stat2">Tecnologías</div>
          </div>
          <div class="glass rounded-xl p-5 text-center glass-hover">
            <div class="font-['Space_Grotesk'] font-bold text-3xl t-accent2">QML</div>
            <div class="text-xs t-text-40 mt-1 font-['JetBrains_Mono']" data-i18n="hero.research">Research</div>
          </div>
        </div>

        <!-- Interests -->
        <div class="flex flex-wrap gap-3 pt-2 reveal" style="transition-delay:0.4s;">
          <span class="font-['JetBrains_Mono'] text-xs t-text-30 mr-2 self-center" data-i18n="about.interests">Intereses:</span>
          {['🎮 Videojuegos', '🏀 Baloncesto', '🎬 Cine', '🧠 IA'].map((interest) => (
            <span class="px-3 py-1.5 glass rounded-full text-xs t-text-50 hover:t-text transition-all duration-300">
              {interest}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
