---
---

<section id="experience" class="py-32 relative">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid lg:grid-cols-2 gap-20">

      <!-- Work Experience -->
      <div>
        <div class="mb-12 space-y-4">
          <div class="reveal"><span class="section-label" data-i18n="exp.label">Experiencia</span></div>
          <h2 class="text-4xl md:text-5xl font-['Space_Grotesk'] font-bold reveal delay-1">
            <span data-i18n="exp.t1">Experiencia</span><span class="t-accent" data-i18n="exp.t2"> Laboral</span>
          </h2>
        </div>

        <div class="space-y-6">
          <!-- Job 1 -->
          <div class="reveal group delay-1">
            <div class="glass glass-hover rounded-2xl p-6 md:p-8 relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-px grad-accent-line"></div>
              <div class="flex items-start justify-between flex-wrap gap-4 mb-4">
                <div>
                  <h3 class="font-['Space_Grotesk'] font-bold text-xl t-text group-hover:t-accent transition-colors duration-300" data-i18n="exp.role1">Investigador</h3>
                  <p class="font-['JetBrains_Mono'] text-sm mt-1 text-accent-60">SPILab by Quercus</p>
                </div>
                <span class="font-['JetBrains_Mono'] text-xs t-text-30 px-3 py-1.5 glass rounded-full shrink-0">Feb 2025 — May 2025</span>
              </div>
              <p class="t-text-40 text-sm leading-relaxed mb-5" data-i18n="exp.desc1">
                Desarrollo de trabajo comparativo entre Quantum Machine Learning y Classical Machine Learning. Implementación de algoritmos de Quantum Machine Learning en Qiskit y Pennylane y comparación con algoritmos clásicos.
              </p>
              <div class="flex flex-wrap gap-2">
                {['Python', 'Qiskit', 'PennyLane', 'Machine Learning'].map((tag) => (
                  <span class="px-3 py-1 rounded-full accent-bg-5 accent-border border font-['JetBrains_Mono'] text-[11px] t-accent">{tag}</span>
                ))}
              </div>
            </div>
          </div>

          <!-- Job 2 -->
          <div class="reveal group delay-2">
            <div class="glass glass-hover rounded-2xl p-6 md:p-8 relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-px grad-accent-line"></div>
              <div class="flex items-start justify-between flex-wrap gap-4 mb-4">
                <div>
                  <h3 class="font-['Space_Grotesk'] font-bold text-xl t-text group-hover:t-accent transition-colors duration-300" data-i18n="exp.role2">Operador de Base de Datos</h3>
                  <p class="font-['JetBrains_Mono'] text-sm mt-1 text-accent-60">Alfotrailer, S.L.</p>
                </div>
                <span class="font-['JetBrains_Mono'] text-xs t-text-30 px-3 py-1.5 glass rounded-full shrink-0">May 2024 — Jul 2024</span>
              </div>
              <p class="t-text-40 text-sm leading-relaxed mb-5" data-i18n="exp.desc2">
                Asistencia en la resolución de problemas relacionados con bases de datos e implementación de soluciones. Actualización y modificación de registros en la base de datos.
              </p>
              <div class="flex flex-wrap gap-2">
                {['SQL', 'Database', 'Problem Solving'].map((tag) => (
                  <span class="px-3 py-1 rounded-full accent-bg-5 accent-border border font-['JetBrains_Mono'] text-[11px] t-accent">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Education -->
      <div>
        <div class="mb-12 space-y-4">
          <div class="reveal"><span class="section-label" data-i18n="edu.label">Educación</span></div>
          <h2 class="text-4xl md:text-5xl font-['Space_Grotesk'] font-bold reveal delay-1">
            <span data-i18n="edu.t1">Formación</span><span class="t-accent2" data-i18n="edu.t2"> Académica</span>
          </h2>
        </div>

        <div class="space-y-6">
          <!-- Edu 1 -->
          <div class="reveal group delay-1">
            <div class="glass glass-hover rounded-2xl p-6 md:p-8 relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-px grad-accent2-line"></div>
              <div class="absolute top-4 right-4 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full animate-pulse bg-accent2-solid"></span>
                <span class="font-['JetBrains_Mono'] text-[10px] t-accent2" data-i18n="edu.current">En curso</span>
              </div>
              <div class="mb-4">
                <h3 class="font-['Space_Grotesk'] font-bold text-xl t-text group-hover:t-accent2 transition-colors duration-300 pr-20" data-i18n="edu.role1">Máster en Inteligencia Artificial</h3>
                <p class="font-['JetBrains_Mono'] text-sm mt-1 text-accent2l-60">Universidad Alfonso X el Sabio (UAX)</p>
                <span class="font-['JetBrains_Mono'] text-xs t-text-30 mt-2 inline-block">2025 — Presente</span>
              </div>
              <p class="t-text-40 text-sm leading-relaxed mb-5" data-i18n="edu.desc1">
                Master oficial basado en la especialización en técnicas avanzadas de IA, Machine Learning y Deep Learning.
              </p>
              <div class="flex flex-wrap gap-2">
                {['IA', 'Machine Learning', 'Deep Learning'].map((tag) => (
                  <span class="px-3 py-1 rounded-full accent2-bg-5 accent2-border border font-['JetBrains_Mono'] text-[11px] t-accent2">{tag}</span>
                ))}
              </div>
            </div>
          </div>

          <!-- Edu 2 -->
          <div class="reveal group delay-2">
            <div class="glass glass-hover rounded-2xl p-6 md:p-8 relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-px grad-accent2-line"></div>
              <div class="mb-4">
                <h3 class="font-['Space_Grotesk'] font-bold text-xl t-text group-hover:t-accent2 transition-colors duration-300" data-i18n="edu.role2">Grado en Ingeniería Informática — Ing. Software</h3>
                <p class="font-['JetBrains_Mono'] text-sm mt-1 text-accent2l-60">Universidad de Extremadura</p>
                <span class="font-['JetBrains_Mono'] text-xs t-text-30 mt-2 inline-block">2020 — 2025</span>
              </div>
              <p class="t-text-40 text-sm leading-relaxed mb-5" data-i18n="edu.desc2">
                Formación integral en desarrollo de software, ingeniería de sistemas y gestión de proyectos tecnológicos.
              </p>
              <div class="flex flex-wrap gap-2">
                {['Software Engineering', 'Systems', 'Project Management'].map((tag) => (
                  <span class="px-3 py-1 rounded-full accent2-bg-5 accent2-border border font-['JetBrains_Mono'] text-[11px] t-accent2">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Extra info card -->
        <div class="mt-6 glass rounded-2xl p-6 reveal delay-3">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl accent-bg-10 flex items-center justify-center shrink-0">
              <span class="text-2xl">🎓</span>
            </div>
            <div>
              <p class="text-sm t-text-50" data-i18n="edu.learning">Siempre aprendiendo</p>
              <p class="text-xs t-text-30 font-['JetBrains_Mono'] mt-1" data-i18n="edu.learndesc">Actualmente especializándome en IA</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
