---

<footer class="border-t t-border py-12">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-3 gap-8 items-center">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg accent-bg-10 accent-border border flex items-center justify-center">
          <span class="font-['Space_Grotesk'] font-bold t-accent text-sm">A</span>
        </div>
        <span class="font-['Space_Grotesk'] text-sm t-text-40">
          alberto<span class="t-accent">.dev</span>
        </span>
      </div>

      <!-- Center -->
      <div class="text-center">
        <p class="t-text-50 text-sm font-['JetBrains_Mono']">© 2026 Alberto Fernández</p>
        <p class="t-text-30 text-xs font-['JetBrains_Mono'] mt-1">
          <span data-i18n="footer.made">Hecho con</span> <span class="text-red-400/50">❤</span> & <span class="text-amber-400/50">☕</span> <span data-i18n="footer.using">usando Astro & TailwindCSS</span>
        </p>
      </div>

      <!-- Right -->
      <div class="flex items-center justify-end gap-4">
        <a href="#home" class="t-text-40 hover:t-accent text-xs font-['JetBrains_Mono'] transition-colors" data-cursor data-i18n="footer.back">
          ↑ Volver arriba
        </a>
      </div>
    </div>
  </div>
</footer>
