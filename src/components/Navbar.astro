---
const navItems = [
  { key: 'nav.home', label: 'Inicio', href: '#home' },
  { key: 'nav.about', label: 'Sobre mí', href: '#about' },
  { key: 'nav.skills', label: 'Skills', href: '#skills' },
  { key: 'nav.experience', label: 'Experiencia', href: '#experience' },
  { key: 'nav.projects', label: 'Proyectos', href: '#projects' },
  { key: 'nav.contact', label: 'Contacto', href: '#contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 py-4 px-6 md:px-12 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a href="#home" class="group flex items-center gap-2" data-cursor>
      <div class="w-10 h-10 rounded-lg accent-bg-10 accent-border border flex items-center justify-center group-hover:bg-[color-mix(in_srgb,var(--c-accent)_20%,transparent)] transition-all duration-300">
        <span class="font-['Space_Grotesk'] font-bold t-accent text-lg">A</span>
      </div>
      <span class="font-['Space_Grotesk'] font-semibold text-sm t-text-70 group-hover:t-text transition-colors hidden sm:block">alberto<span class="t-accent">.dev</span></span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-1 glass glass-blur rounded-full px-2 py-1.5">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="px-4 py-1.5 rounded-full text-sm t-text-40 hover:t-text hover:bg-[var(--c-glass-h)] transition-all duration-300 font-['Space_Grotesk']"
          data-cursor
          data-i18n={item.key}
        >
          {item.label}
        </a>
      ))}
    </div>

    <!-- Right controls -->
    <div class="flex items-center gap-2">
      <!-- Language Toggle -->
      <button
        id="btn-lang"
        class="w-10 h-10 glass rounded-lg flex items-center justify-center font-['JetBrains_Mono'] text-xs font-bold t-accent hover:bg-[var(--c-glass-h)] transition-all duration-300"
        data-cursor
        aria-label="Toggle language"
      >
        EN
      </button>

      <!-- Theme Toggle -->
      <button
        id="btn-theme"
        class="w-10 h-10 glass rounded-lg flex items-center justify-center t-text-40 hover:t-accent hover:bg-[var(--c-glass-h)] transition-all duration-300"
        data-cursor
        aria-label="Toggle theme"
      >
        <!-- Sun icon (shown in dark mode → click to go light) -->
        <svg id="icon-sun" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <!-- Moon icon (shown in light mode → click to go dark) -->
        <svg id="icon-moon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>

      <!-- Download CV (desktop) -->
      <a
        href="/cv.pdf"
        target="_blank"
        class="hidden md:flex items-center gap-2 px-5 py-2.5 accent-bg rounded-full font-['Space_Grotesk'] font-semibold text-sm hover:shadow-[0_0_30px_color-mix(in_srgb,var(--c-accent)_30%,transparent)] transition-all duration-300 text-c-bg"
        data-cursor
      >
        <span data-i18n="nav.cv">Descargar CV</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4l4-4M4 18h16" />
        </svg>
      </a>

      <!-- Mobile Menu Toggle -->
      <button id="mobile-toggle" class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 glass rounded-lg" data-cursor>
        <span class="w-5 h-0.5 t-text-70 transition-all duration-300 origin-center bg-current" id="bar1"></span>
        <span class="w-5 h-0.5 t-text-70 transition-all duration-300 bg-current" id="bar2"></span>
        <span class="w-3.5 h-0.5 t-text-70 transition-all duration-300 origin-center bg-current" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden max-w-7xl mx-auto mt-4 glass glass-blur rounded-2xl p-6 hidden opacity-0 translate-y-[-10px] transition-all duration-300">
    <div class="flex flex-col gap-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="px-4 py-3 rounded-xl t-text-40 hover:t-text hover:bg-[var(--c-glass-h)] transition-all duration-300 font-['Space_Grotesk'] text-lg mobile-nav-link"
          data-i18n={item.key}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/cv.pdf"
        target="_blank"
        class="mt-4 flex items-center justify-center gap-2 px-5 py-3 accent-bg rounded-xl font-['Space_Grotesk'] font-semibold text-c-bg"
      >
        <span data-i18n="nav.cv">Descargar CV</span>
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  let navScrolled = false;
  let ticking = false;
  function updateNavbar() {
    const scrolled = window.scrollY > 80;
    if (scrolled !== navScrolled) {
      navScrolled = scrolled;
      if (scrolled) {
        navbar?.classList.add('backdrop-blur-xl', 'border-b');
        navbar!.style.backgroundColor = 'color-mix(in srgb, var(--c-bg) 70%, transparent)';
        navbar!.style.borderColor = 'var(--c-glass-b)';
      } else {
        navbar?.classList.remove('backdrop-blur-xl', 'border-b');
        navbar!.style.backgroundColor = '';
        navbar!.style.borderColor = '';
      }
    }
    ticking = false;
  }
  window.addEventListener('scroll', () => {
    if (!ticking) { ticking = true; requestAnimationFrame(updateNavbar); }
  }, { passive: true });

  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let isOpen = false;
  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu?.classList.remove('hidden');
      setTimeout(() => { menu?.classList.remove('opacity-0','translate-y-[-10px]'); menu?.classList.add('opacity-100','translate-y-0'); }, 10);
      bar1?.classList.add('rotate-45','translate-y-[4px]');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-rotate-45','translate-y-[-4px]','!w-5');
    } else {
      menu?.classList.add('opacity-0','translate-y-[-10px]');
      menu?.classList.remove('opacity-100','translate-y-0');
      setTimeout(() => menu?.classList.add('hidden'), 300);
      bar1?.classList.remove('rotate-45','translate-y-[4px]');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45','translate-y-[-4px]','!w-5');
    }
  });
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => { if (isOpen) toggle?.click(); });
  });
</script>
