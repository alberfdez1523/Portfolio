---
const skills = [
  { name: 'Python', category: 'Programming', icon: '🐍', level: 90, color: 'from-yellow-400/20 to-blue-500/20' },
  { name: 'R', category: 'Programming', icon: '📊', level: 75, color: 'from-blue-400/20 to-blue-600/20' },
  { name: 'Java', category: 'Programming', icon: '☕', level: 80, color: 'from-orange-400/20 to-red-500/20' },
  { name: 'React', category: 'Frontend', icon: '⚛️', level: 80, color: 'from-cyan-400/20 to-blue-500/20' },
  { name: 'Astro', category: 'Frontend', icon: '🚀', level: 85, color: 'from-orange-400/20 to-pink-500/20' },
  { name: 'Tailwind CSS', category: 'Frontend', icon: '🎨', level: 90, color: 'from-teal-400/20 to-cyan-500/20' },
  { name: 'SQL', category: 'Database', icon: '🗄️', level: 75, color: 'from-gray-400/20 to-gray-600/20' },
  { name: 'PennyLane', category: 'Quantum', icon: '🔮', level: 70, color: 'from-purple-400/20 to-pink-500/20' },
  { name: 'Qiskit', category: 'Quantum', icon: '⚛️', level: 70, color: 'from-indigo-400/20 to-purple-600/20' },
];

const categories = [
  { name: 'Programming', color: 'bg-yellow-400' },
  { name: 'Frontend', color: 'bg-cyan-400' },
  { name: 'Database', color: 'bg-gray-400' },
  { name: 'Quantum', color: 'bg-purple-400' },
];
---

<section id="skills" class="py-32 relative">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="text-center mb-16 space-y-4">
      <div class="reveal flex justify-center">
        <span class="section-label" data-i18n="skills.label">Habilidades</span>
      </div>
      <h2 class="text-4xl md:text-6xl font-['Space_Grotesk'] font-bold reveal delay-1">
        Tech <span class="t-accent">Stack</span>
      </h2>
      <p class="t-text-40 max-w-lg mx-auto reveal delay-2" data-i18n="skills.desc">
        Herramientas y tecnologías con las que trabajo día a día
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4 stagger-children">
      {skills.map((skill, index) => (
        <div class={`group glass glass-hover rounded-2xl p-5 md:p-6 relative overflow-hidden ${index === 0 ? 'md:col-span-2 md:row-span-2' : ''} ${index === 4 ? 'md:col-span-2' : ''}`}>
          <div class={`absolute inset-0 bg-gradient-to-br ${skill.color} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>
          <div class="relative z-10">
            <div class="flex items-start justify-between mb-3">
              <span class={`text-${index === 0 ? '3xl md:text-4xl' : '2xl'}`}>{skill.icon}</span>
              <span class="font-['JetBrains_Mono'] text-[10px] t-text-20 uppercase tracking-wider px-2 py-1 rounded-full border t-border">
                {skill.category}
              </span>
            </div>
            <h3 class={`font-['Space_Grotesk'] font-bold ${index === 0 ? 'text-2xl md:text-3xl' : 'text-lg'} t-text group-hover:t-text transition-colors mt-3`}>
              {skill.name}
            </h3>
            <div class="mt-4">
              <div class="h-1 rounded-full overflow-hidden bg-text-05">
                <div class="h-full rounded-full transition-all duration-1000 ease-out" style="width:0%;background:linear-gradient(to right, var(--c-accent), var(--c-accent2));" data-width={`${skill.level}%`}></div>
              </div>
            </div>
            {index === 0 && (
              <p class="t-text-30 text-sm mt-4 hidden md:block" data-i18n="skills.pydesc">
                Lenguaje principal para IA, Machine Learning y desarrollo de algoritmos cuánticos.
              </p>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Category pills -->
    <div class="flex flex-wrap justify-center gap-3 mt-12 reveal">
      {categories.map((cat) => (
        <div class="flex items-center gap-2 px-4 py-2 glass rounded-full">
          <div class={`w-2 h-2 rounded-full ${cat.color}`}></div>
          <span class="font-['JetBrains_Mono'] text-xs t-text-50">{cat.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('[data-width]').forEach((bar, i) => {
          setTimeout(() => { (bar as HTMLElement).style.width = bar.getAttribute('data-width') || '0%'; }, i * 100);
        });
      }
    });
  }, { threshold: 0.2 });
  const s = document.getElementById('skills');
  if (s) obs.observe(s);
</script>
