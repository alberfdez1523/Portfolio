---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth" data-theme="dark" data-lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Alberto Fernández - Ingeniero de Software & IA" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" /></noscript>
    <title>{title}</title>

    <!-- Prevent FOUC: apply saved theme/lang before render -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('theme') || 'dark';
        var l = localStorage.getItem('lang') || 'es';
        document.documentElement.setAttribute('data-theme', t);
        document.documentElement.setAttribute('data-lang', l);
        document.documentElement.lang = l;
      })();
    </script>
  </head>
  <body class="antialiased font-['Inter'] overflow-x-hidden transition-colors duration-500 bg-body text-body">
    <!-- Grain overlay (static – no animation, GPU-composited) -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <!-- Gradient orbs (GPU-composited, reduced blur) -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden" aria-hidden="true">
      <div class="orb-accent absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full blur-[80px] animate-float"></div>
      <div class="orb-accent2 absolute top-1/2 -left-40 w-[500px] h-[500px] rounded-full blur-[80px] animate-float" style="animation-delay:-3s;"></div>
      <div class="orb-accent3 absolute bottom-0 right-1/3 w-[400px] h-[400px] rounded-full blur-[60px] animate-float" style="animation-delay:-5s;"></div>
    </div>

    <Navbar />

    <main class="relative z-10">
      <slot />
    </main>

    <Footer />

    <style is:global>
      @tailwind base;
      @tailwind components;
      @tailwind utilities;

      /* ========= THEME VARIABLES ========= */
      :root,
      [data-theme="dark"] {
        --c-bg:        #050506;
        --c-bg2:       #09090b;
        --c-text:      #ffffff;
        --c-text-70:   rgba(255,255,255,0.7);
        --c-text-50:   rgba(255,255,255,0.5);
        --c-text-40:   rgba(255,255,255,0.4);
        --c-text-30:   rgba(255,255,255,0.3);
        --c-text-20:   rgba(255,255,255,0.2);
        --c-text-10:   rgba(255,255,255,0.1);
        --c-text-05:   rgba(255,255,255,0.05);
        --c-glass:     rgba(255,255,255,0.03);
        --c-glass-h:   rgba(255,255,255,0.06);
        --c-glass-b:   rgba(255,255,255,0.06);
        --c-accent:    #c8ff00;
        --c-accent2:   #7B61FF;
        --c-accent2-l: #9d85ff;
        --c-img-opacity: 0.8;
        --c-grain:     0.4;
        --c-orb-a:     rgba(200,255,0,0.05);
        --c-orb-b:     rgba(123,97,255,0.05);
        --c-scroll-track:#09090b;
        --c-scroll-thumb:#27272a;
        --c-selection: rgba(200,255,0,0.3);
        --c-surface-950: #050506;
        --c-invert: 0;
      }

      [data-theme="light"] {
        --c-bg:        #f5f2ed;
        --c-bg2:       #faf8f4;
        --c-text:      #18181b;
        --c-text-70:   rgba(0,0,0,0.7);
        --c-text-50:   rgba(0,0,0,0.55);
        --c-text-40:   rgba(0,0,0,0.5);
        --c-text-30:   rgba(0,0,0,0.35);
        --c-text-20:   rgba(0,0,0,0.2);
        --c-text-10:   rgba(0,0,0,0.1);
        --c-text-05:   rgba(0,0,0,0.04);
        --c-glass:     rgba(0,0,0,0.03);
        --c-glass-h:   rgba(0,0,0,0.06);
        --c-glass-b:   rgba(0,0,0,0.08);
        --c-accent:    #6d9900;
        --c-accent2:   #5a3fcc;
        --c-accent2-l: #6b4de0;
        --c-img-opacity: 1;
        --c-grain:     0.12;
        --c-orb-a:     rgba(200,255,0,0.08);
        --c-orb-b:     rgba(123,97,255,0.06);
        --c-scroll-track:#ece9e3;
        --c-scroll-thumb:#d4d4d8;
        --c-selection: rgba(109,153,0,0.25);
        --c-surface-950: #f5f2ed;
        --c-invert: 1;
      }

      /* ========= BASE ========= */
      .bg-body  { background-color: var(--c-bg); }
      .text-body{ color: var(--c-text); }

      ::selection {
        background: var(--c-selection);
        color: var(--c-text);
      }

      ::-webkit-scrollbar { width:6px; }
      ::-webkit-scrollbar-track { background: var(--c-scroll-track); }
      ::-webkit-scrollbar-thumb { background: var(--c-scroll-thumb); border-radius:3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--c-accent); }

      /* Grain (static – no animation to avoid constant recomposite of 200% overlay) */
      .grain-overlay {
        position:fixed;inset:0;
        width:100%;height:100%;
        background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
        background-repeat:repeat;
        pointer-events:none;z-index:9999;
        opacity:var(--c-grain);
        transform:translateZ(0);
      }

      /* Orbs */
      .orb-accent  { background:var(--c-orb-a); }
      .orb-accent2 { background:var(--c-orb-b); }
      .orb-accent3 { background:var(--c-orb-a); }

      /* Glass (lightweight – use backdrop-filter only on key elements via .glass-blur) */
      .glass {
        background: var(--c-glass);
        border: 1px solid var(--c-glass-b);
        transition: background 0.3s, border-color 0.3s;
        transform: translateZ(0);
      }
      .glass-blur {
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
      .glass-hover {
        transition: transform 0.3s cubic-bezier(0.16,1,0.3,1),
                    background 0.3s cubic-bezier(0.16,1,0.3,1),
                    border-color 0.3s cubic-bezier(0.16,1,0.3,1),
                    box-shadow 0.3s cubic-bezier(0.16,1,0.3,1);
      }
      .glass-hover:hover {
        background: var(--c-glass-h);
        border-color: color-mix(in srgb, var(--c-accent) 25%, transparent);
        transform: translateY(-4px) translateZ(0);
        box-shadow: 0 20px 40px -12px rgba(0,0,0,0.25);
      }

      /* Themed text utilities */
      .t-text      { color: var(--c-text); }
      .t-text-70   { color: var(--c-text-70); }
      .t-text-50   { color: var(--c-text-50); }
      .t-text-40   { color: var(--c-text-40); }
      .t-text-30   { color: var(--c-text-30); }
      .t-text-20   { color: var(--c-text-20); }
      .t-text-10   { color: var(--c-text-10); }
      .t-text-05   { color: var(--c-text-05); }
      .t-accent    { color: var(--c-accent); }
      .t-accent2   { color: var(--c-accent2-l); }
      .t-bg        { background-color: var(--c-bg); }
      .t-bg2       { background-color: var(--c-bg2); }
      .t-surface   { background-color: var(--c-surface-950); }
      .t-border    { border-color: var(--c-glass-b); }

      .accent-bg   { background-color: var(--c-accent); }
      .accent-border { border-color: color-mix(in srgb, var(--c-accent) 20%, transparent); }
      .accent2-border{ border-color: color-mix(in srgb, var(--c-accent2) 20%, transparent); }
      .accent-bg-10 { background: color-mix(in srgb, var(--c-accent) 10%, transparent); }
      .accent2-bg-10{ background: color-mix(in srgb, var(--c-accent2) 10%, transparent); }
      .accent-bg-5  { background: color-mix(in srgb, var(--c-accent) 5%, transparent); }
      .accent2-bg-5 { background: color-mix(in srgb, var(--c-accent2) 5%, transparent); }

      /* Section label */
      .section-label {
        font-family:'JetBrains Mono',monospace;
        font-size:0.75rem;letter-spacing:0.2em;text-transform:uppercase;
        color:var(--c-accent);display:flex;align-items:center;gap:0.75rem;
      }
      .section-label::before {
        content:'';display:inline-block;width:2rem;height:1px;background:var(--c-accent);
      }

      /* Reveal animations */
      .reveal {
        opacity:0;transform:translateY(30px);
        transition:all 0.8s cubic-bezier(0.16,1,0.3,1);
      }
      .reveal.visible { opacity:1;transform:translateY(0); }

      .stagger-children > * {
        opacity:0;transform:translateY(20px);
        transition:all 0.6s cubic-bezier(0.16,1,0.3,1);
      }
      .stagger-children.visible > *:nth-child(1){transition-delay:.05s}
      .stagger-children.visible > *:nth-child(2){transition-delay:.1s}
      .stagger-children.visible > *:nth-child(3){transition-delay:.15s}
      .stagger-children.visible > *:nth-child(4){transition-delay:.2s}
      .stagger-children.visible > *:nth-child(5){transition-delay:.25s}
      .stagger-children.visible > *:nth-child(6){transition-delay:.3s}
      .stagger-children.visible > *:nth-child(7){transition-delay:.35s}
      .stagger-children.visible > *:nth-child(8){transition-delay:.4s}
      .stagger-children.visible > *:nth-child(9){transition-delay:.45s}
      .stagger-children.visible > *:nth-child(10){transition-delay:.5s}
      .stagger-children.visible > *:nth-child(11){transition-delay:.55s}
      .stagger-children.visible > * { opacity:1;transform:translateY(0); }

      /* Cursor (GPU-composited, use translate instead of left/top) */
      .cursor-dot {
        width:8px;height:8px;background:var(--c-accent);border-radius:50%;
        position:fixed;top:0;left:0;pointer-events:none;z-index:99999;
        mix-blend-mode:difference;
        transition:transform .15s ease-out, opacity .15s ease-out;
        will-change:transform;
        contain:layout style;
      }
      @media (pointer:coarse) {
        .cursor-dot { display:none !important; }
      }

      /* Animations */
      @keyframes float {
        0%,100%{transform:translateY(0)}50%{transform:translateY(-20px)}
      }
      /* grain animation removed — static grain is much cheaper */
      @keyframes marquee {
        0%{transform:translateX(0)}100%{transform:translateX(-50%)}
      }
      .animate-float { animation:float 6s ease-in-out infinite; contain:layout style; }
      .animate-marquee{ animation:marquee 25s linear infinite; contain:layout style; }

      /* Reduced motion – disable all expensive animations */
      @media (prefers-reduced-motion: reduce) {
        .grain-overlay { display:none; }
        .animate-float { animation:none !important; }
        .animate-marquee { animation:none !important; }
        .reveal { opacity:1 !important; transform:none !important; transition:none !important; }
        .stagger-children > * { opacity:1 !important; transform:none !important; transition:none !important; }
        * { transition-duration:0.01ms !important; animation-duration:0.01ms !important; }
      }

      /* Gradient from surface */
      .grad-from-surface { --tw-gradient-from: var(--c-surface-950); }

      /* image themed opacity */
      .t-img { opacity: var(--c-img-opacity); }

      /* ========= PERFORMANCE ========= */
      /* content-visibility: auto skips rendering for off-screen sections */
      section {
        content-visibility: auto;
        contain-intrinsic-size: auto 700px;
      }
      #home {
        content-visibility: visible;
        contain-intrinsic-size: auto 100vh;
      }
      /* GPU compositing for animated elements */
      .orb-accent, .orb-accent2, .orb-accent3 {
        will-change: transform;
        contain: layout style;
        transform: translateZ(0);
      }
    </style>

